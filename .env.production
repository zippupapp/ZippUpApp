# Production Environment Configuration
NODE_ENV="production"

# Database - Supabase (Production)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Authentication
JWT_SECRET="[GENERATE-A-SECURE-32-CHARACTER-SECRET]"
NEXTAUTH_SECRET="[GENERATE-A-SECURE-32-CHARACTER-SECRET]"
NEXTAUTH_URL="https://your-domain.com"

# Twilio (SMS/WhatsApp) - Production
TWILIO_ACCOUNT_SID="[YOUR-PRODUCTION-TWILIO-SID]"
TWILIO_AUTH_TOKEN="[YOUR-PRODUCTION-TWILIO-TOKEN]"
TWILIO_PHONE_NUMBER="[YOUR-PRODUCTION-TWILIO-NUMBER]"

# Payment Gateways - Production
STRIPE_PUBLISHABLE_KEY="pk_live_[YOUR-LIVE-STRIPE-KEY]"
STRIPE_SECRET_KEY="sk_live_[YOUR-LIVE-STRIPE-KEY]"
STRIPE_WEBHOOK_SECRET="whsec_[YOUR-LIVE-WEBHOOK-SECRET]"

FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_[YOUR-LIVE-KEY]"
FLUTTERWAVE_SECRET_KEY="FLWSECK_[YOUR-LIVE-KEY]"

PAYSTACK_PUBLIC_KEY="pk_live_[YOUR-LIVE-KEY]"
PAYSTACK_SECRET_KEY="sk_live_[YOUR-LIVE-KEY]"

# Maps & Location - Production
GOOGLE_MAPS_API_KEY="[YOUR-PRODUCTION-GOOGLE-MAPS-KEY]"
MAPBOX_ACCESS_TOKEN="[YOUR-PRODUCTION-MAPBOX-TOKEN]"

# AI & Search - Production
OPENAI_API_KEY="sk-[YOUR-PRODUCTION-OPENAI-KEY]"
ALGOLIA_APP_ID="[YOUR-PRODUCTION-ALGOLIA-APP-ID]"
ALGOLIA_API_KEY="[YOUR-PRODUCTION-ALGOLIA-API-KEY]"
ALGOLIA_SEARCH_KEY="[YOUR-PRODUCTION-ALGOLIA-SEARCH-KEY]"

# Email Service - Production
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="[YOUR-PRODUCTION-EMAIL]"
SMTP_PASS="[YOUR-PRODUCTION-EMAIL-PASSWORD]"

# File Storage - Production
CLOUDINARY_CLOUD_NAME="[YOUR-PRODUCTION-CLOUDINARY-NAME]"
CLOUDINARY_API_KEY="[YOUR-PRODUCTION-CLOUDINARY-API-KEY]"
CLOUDINARY_API_SECRET="[YOUR-PRODUCTION-CLOUDINARY-API-SECRET]"

# Real-time Communication - Production
SOCKET_IO_URL="https://your-domain.com"
REDIS_URL="[YOUR-PRODUCTION-REDIS-URL]"

# App Configuration - Production
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_API_URL="https://your-domain.com/api"

# Admin Configuration - Production
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PHONE="[YOUR-ADMIN-PHONE]"

# Emergency Services - Production
EMERGENCY_DISPATCH_API_URL="[YOUR-EMERGENCY-API-URL]"
EMERGENCY_DISPATCH_API_KEY="[YOUR-EMERGENCY-API-KEY]"

# Commission Rates
SERVICE_COMMISSION_RATE="0.20"
DIGITAL_COMMISSION_RATE="0.05"
MARKETPLACE_COMMISSION_RATE="0.10"

# WhatsApp Business API - Production
WHATSAPP_ACCESS_TOKEN="[YOUR-PRODUCTION-WHATSAPP-TOKEN]"
WHATSAPP_PHONE_NUMBER_ID="[YOUR-PRODUCTION-PHONE-NUMBER-ID]"
WHATSAPP_VERIFY_TOKEN="[YOUR-PRODUCTION-VERIFY-TOKEN]"

# Push Notifications - Production
FCM_SERVER_KEY="[YOUR-PRODUCTION-FCM-SERVER-KEY]"
FCM_PROJECT_ID="[YOUR-PRODUCTION-FIREBASE-PROJECT-ID]"

# Analytics - Production
GOOGLE_ANALYTICS_ID="[YOUR-PRODUCTION-GA-ID]"

# Security - Production
CORS_ORIGIN="https://your-domain.com"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="900000"
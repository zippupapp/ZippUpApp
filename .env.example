# Commission Rates (as decimals)
SERVICE_COMMISSION_RATE="0.20"  # 20%
DIGITAL_COMMISSION_RATE="0.05"  # 5%
MARKETPLACE_COMMISSION_RATE="0.10"  # 10%

# WhatsApp Business API
